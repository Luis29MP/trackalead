# ─────────────────────────────────────────────────────────────
# TrackALead — variables de entorno (cliente / Vite)
# Copia este archivo a .env.local y rellena los valores reales.
# Todas las VITE_* quedan EXPUESTAS en el bundle del navegador:
# usa SOLO claves públicas (anon key, no service_role).
# ─────────────────────────────────────────────────────────────

# Supabase (Project Settings → API)
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica

# Google Maps JavaScript API (restringe la clave por dominio)
VITE_GOOGLE_MAPS_API_KEY=tu-google-maps-key

# Nota: las claves de IA (Anthropic/OpenAI/Gemini) NO van aquí.
# Cada usuario las guarda cifradas desde la app (Edge Function ai-proxy).
